datanexusmcp.com {
  log {
    output file /var/log/caddy/access.log {
      roll_size 50mb
      roll_keep 5
    }
    format json
  }

  # ── Block credential scanners ──────────────────
  @blocked {
    remote_ip 176.65.148.38
  }
  respond @blocked 403

  # ── Dashboard — ops IP only ────────────────────
  @ops_ip {
    remote_ip 178.104.251.70
  }
  handle /ops/dashboard* {
    reverse_proxy @ops_ip datanexus-mcp:8101
    respond 403
  }

  # ── Static homepage, privacy, docs ────────────
  root * /app/datanexus/static

  handle / {
    file_server
  }

  handle /privacy* {
    file_server
  }

  handle /docs* {
    file_server
  }

  handle /use-case-cards.html {
    file_server
  }

  # ── MCP server (all other routes) ─────────────
  handle {
    reverse_proxy datanexus-mcp:8000 {
      flush_interval -1
      header_up Accept "application/json"
      header_up X-Real-IP {remote_host}
      header_up X-Forwarded-For {remote_host}
      transport http {
        versions 1.1
      }
    }
  }
}
